.login select{border:1px solid #334155;border-radius:12px;background:#0a0e1a;padding:13px;color:#fff;outline:0}.auth-tabs{display:flex;gap:8px;margin:22px 0 5px}.auth-tabs button{flex:1;border:1px solid #334155;background:#0a0e1a;color:#94a3b8;padding:10px;border-radius:10px;font-size:.8rem}.auth-tabs .selected{background:#6366f1;color:#fff;border-color:#818cf8}.auth-error{color:#fca5a5!important;font-size:.82rem;margin:0}.dot.milestone{fill:#fbbf24;filter:drop-shadow(0 0 6px #fbbf24)}
